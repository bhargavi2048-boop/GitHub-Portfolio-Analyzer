{
  "name": "github-portfolio-analyzer",
  "version": "2.2.0",
  "description": "Premium GitHub Portfolio Analyzer — enterprise-grade SaaS backend (UI preserved).",
  "main": "src/server.js",
  "scripts": {
    "setup": "node setup.js",
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest --runInBand",
    "test:coverage": "jest --coverage --runInBand",
    "lint": "eslint \"src/**/*.js\" \"tests/**/*.js\"",
    "lint:fix": "eslint --fix \"src/**/*.js\" \"tests/**/*.js\"",
    "format": "prettier --write \"src/**/*.{js,json}\" \"tests/**/*.js\"",
    "docker:build": "docker build -t gpa:latest .",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "crypto-random-string": "^5.0.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "express-validator": "^7.2.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "node-cache": "^5.1.2",
    "node-cron": "3.0.3",
    "nodemailer": "^6.9.14",
    "openai": "^4.56.0",
    "pdf-parse": "^1.1.1",
    "pdfkit": "^0.15.0",
    "better-sqlite3": "^12.0.0"
  },
  "optionalDependencies": {
    "bullmq": "^5.12.0",
    "ioredis": "^5.4.1",
    "prom-client": "^15.1.0",
    "rate-limit-redis": "^4.2.0"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "nock": "^13.5.6",
    "nodemon": "^3.1.4",
    "prettier": "^3.3.3",
    "supertest": "^7.0.0"
  }
}