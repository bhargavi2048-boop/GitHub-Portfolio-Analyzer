{
  "openapi": "3.0.3",
  "info": {
    "title": "GitHub Portfolio Analyzer API",
    "version": "2.2.0",
    "description": "Production-grade SaaS backend for GitHub portfolio analysis, AI insights, reporting, and leaderboards.",
    "contact": { "name": "API Support", "url": "https://github.com/your-repo" }
  },
  "servers": [{ "url": "/api", "description": "Default" }, { "url": "/api/v1", "description": "Versioned" }],
  "components": {
    "securitySchemes": {
      "bearerAuth": { "type": "http", "scheme": "bearer", "bearerFormat": "JWT" },
      "cookieAuth": { "type": "apiKey", "in": "cookie", "name": "access_token" }
    },
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "error": { "type": "string", "example": "Invalid GitHub username" },
          "code": { "type": "string", "example": "INVALID_USERNAME" },
          "requestId": { "type": "string", "example": "req-abc123" }
        }
      },
      "ValidationError": {
        "type": "object",
        "properties": {
          "errors": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "msg": { "type": "string" },
                "param": { "type": "string" },
                "location": { "type": "string" }
              }
            }
          }
        }
      },
      "Health": {
        "type": "object",
        "properties": {
          "status": { "type": "string", "enum": ["ok", "degraded"] },
          "ts": { "type": "integer" },
          "uptime": { "type": "integer" }
        }
      },
      "Score": {
        "type": "object",
        "properties": {
          "total": { "type": "integer", "minimum": 0, "maximum": 100 },
          "ats": { "type": "integer", "minimum": 0, "maximum": 100 },
          "rank": { "type": "string", "enum": ["S", "A", "B", "C", "D"] },
          "pillars": {
            "type": "object",
            "properties": {
              "activity": { "type": "integer" },
              "quality": { "type": "integer" },
              "impact": { "type": "integer" },
              "diversity": { "type": "integer" },
              "documentation": { "type": "integer" }
            }
          }
        }
      },
      "AnalysisResult": {
        "type": "object",
        "properties": {
          "profile": { "type": "object", "description": "GitHub user profile object" },
          "stats": {
            "type": "object",
            "properties": {
              "totalStars": { "type": "integer" },
              "totalForks": { "type": "integer" },
              "languages": { "type": "array", "items": { "type": "object", "properties": { "name": { "type": "string" }, "value": { "type": "integer" } } } },
              "activityByMonth": { "type": "array", "items": { "type": "object", "properties": { "month": { "type": "string" }, "commits": { "type": "integer" } } } },
              "topRepos": { "type": "array", "items": { "type": "object" } },
              "withReadme": { "type": "integer" },
              "withLicense": { "type": "integer" },
              "withTopics": { "type": "integer" }
            }
          },
          "score": { "$ref": "#/components/schemas/Score" }
        }
      },
      "User": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "email": { "type": "string", "format": "email" },
          "name": { "type": "string" },
          "githubLogin": { "type": "string" },
          "avatarUrl": { "type": "string" },
          "emailVerified": { "type": "boolean" }
        }
      },
      "AuthResponse": {
        "type": "object",
        "properties": {
          "token": { "type": "string", "description": "JWT access token (15m expiry)" },
          "refreshToken": { "type": "string", "description": "Refresh token (30d expiry)" },
          "user": { "$ref": "#/components/schemas/User" }
        }
      },
      "LeaderboardEntry": {
        "type": "object",
        "properties": {
          "username": { "type": "string" },
          "avatarUrl": { "type": "string" },
          "score": { "type": "integer" },
          "rank": { "type": "string", "enum": ["S", "A", "B", "C", "D"] },
          "position": { "type": "integer" }
        }
      }
    }
  },
  "security": [{ "bearerAuth": [] }, { "cookieAuth": [] }],
  "paths": {
    "/health": {
      "get": {
        "summary": "Liveness / uptime check",
        "security": [],
        "tags": ["Health"],
        "responses": { "200": { "description": "Server is running", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Health" } } } } }
      }
    },
    "/health/live": {
      "get": {
        "summary": "Kubernetes liveness probe",
        "security": [],
        "tags": ["Health"],
        "responses": { "200": { "description": "Alive" } }
      }
    },
    "/health/ready": {
      "get": {
        "summary": "Kubernetes readiness probe (checks mongo + redis)",
        "security": [],
        "tags": ["Health"],
        "responses": {
          "200": { "description": "All dependencies ready" },
          "503": { "description": "One or more dependencies degraded" }
        }
      }
    },
    "/health/metrics": {
      "get": {
        "summary": "Prometheus metrics endpoint",
        "security": [],
        "tags": ["Health"],
        "responses": { "200": { "description": "Prometheus text format metrics", "content": { "text/plain": {} } } }
      }
    },
    "/auth/register": {
      "post": {
        "summary": "Register a new account",
        "security": [],
        "tags": ["Auth"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "password"],
                "properties": {
                  "email": { "type": "string", "format": "email" },
                  "password": { "type": "string", "minLength": 8 },
                  "name": { "type": "string", "maxLength": 100 }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Account created", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AuthResponse" } } } },
          "400": { "description": "Validation error", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ValidationError" } } } },
          "409": { "description": "Email already in use", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "503": { "description": "Database offline", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/auth/login": {
      "post": {
        "summary": "Login with email and password",
        "security": [],
        "tags": ["Auth"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "password"],
                "properties": {
                  "email": { "type": "string", "format": "email" },
                  "password": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Login successful", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AuthResponse" } } } },
          "400": { "description": "Missing fields" },
          "401": { "description": "Invalid credentials" },
          "423": { "description": "Account locked after too many failed attempts" },
          "503": { "description": "Database offline" }
        }
      }
    },
    "/auth/refresh": {
      "post": {
        "summary": "Rotate refresh token — returns new access + refresh tokens",
        "security": [],
        "tags": ["Auth"],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": { "refreshToken": { "type": "string" } }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "New tokens issued" },
          "400": { "description": "Missing refresh token" },
          "401": { "description": "Invalid or revoked refresh token" }
        }
      }
    },
    "/auth/logout": {
      "post": {
        "summary": "Revoke session (clear cookie + invalidate refresh token)",
        "tags": ["Auth"],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": { "type": "object", "properties": { "refreshToken": { "type": "string" } } }
            }
          }
        },
        "responses": { "204": { "description": "Logged out" } }
      }
    },
    "/auth/me": {
      "get": {
        "summary": "Get current authenticated user",
        "tags": ["Auth"],
        "responses": {
          "200": { "description": "User object", "content": { "application/json": { "schema": { "type": "object", "properties": { "user": { "$ref": "#/components/schemas/User" } } } } } },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/auth/forgot-password": {
      "post": {
        "summary": "Request password reset email",
        "security": [],
        "tags": ["Auth"],
        "requestBody": {
          "content": { "application/json": { "schema": { "type": "object", "required": ["email"], "properties": { "email": { "type": "string", "format": "email" } } } } }
        },
        "responses": { "200": { "description": "Always returns ok (prevents email enumeration)" } }
      }
    },
    "/auth/reset-password": {
      "post": {
        "summary": "Reset password using token from email",
        "security": [],
        "tags": ["Auth"],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "token", "password"],
                "properties": {
                  "email": { "type": "string", "format": "email" },
                  "token": { "type": "string" },
                  "password": { "type": "string", "minLength": 8 }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Password reset" },
          "400": { "description": "Invalid or expired token" }
        }
      }
    },
    "/analyze": {
      "get": {
        "summary": "Analyze a GitHub user's portfolio",
        "security": [],
        "tags": ["Analysis"],
        "parameters": [
          {
            "name": "username",
            "in": "query",
            "required": true,
            "description": "GitHub username (alphanumeric + hyphens, 1-39 chars)",
            "schema": { "type": "string", "pattern": "^[a-zA-Z0-9](?:[a-zA-Z0-9-]{0,38})?$" }
          }
        ],
        "responses": {
          "200": { "description": "Portfolio analysis result", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AnalysisResult" } } } },
          "400": { "description": "Invalid username", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ValidationError" } } } },
          "404": { "description": "GitHub user not found" },
          "429": { "description": "GitHub API rate limit hit" },
          "502": { "description": "GitHub API error" }
        }
      }
    },
    "/analyze/compare": {
      "get": {
        "summary": "Compare two GitHub profiles side-by-side",
        "security": [],
        "tags": ["Analysis"],
        "parameters": [
          { "name": "a", "in": "query", "required": true, "schema": { "type": "string" } },
          { "name": "b", "in": "query", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Side-by-side analysis of two profiles" },
          "400": { "description": "Invalid username(s)" }
        }
      }
    },
    "/ai": {
      "post": {
        "summary": "Get AI-powered portfolio recommendations",
        "tags": ["AI"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["analysis"],
                "properties": { "analysis": { "type": "object", "description": "Analysis result from /analyze endpoint" } }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "AI recommendations including strengths, weaknesses, and project ideas" },
          "400": { "description": "Missing analysis data" },
          "429": { "description": "AI rate limit exceeded" }
        }
      }
    },
    "/leaderboard": {
      "get": {
        "summary": "Get top 50 GitHub profiles by portfolio score",
        "security": [],
        "tags": ["Leaderboard"],
        "responses": {
          "200": {
            "description": "Ranked leaderboard entries",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "leaderboard": { "type": "array", "items": { "$ref": "#/components/schemas/LeaderboardEntry" } },
                    "total": { "type": "integer" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/leaderboard/rank/{username}": {
      "get": {
        "summary": "Get a specific user's rank on the leaderboard",
        "security": [],
        "tags": ["Leaderboard"],
        "parameters": [{ "name": "username", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": {
          "200": { "description": "User rank info" },
          "404": { "description": "User not on leaderboard" }
        }
      }
    },
    "/reports": {
      "get": { "summary": "List saved analysis reports", "tags": ["Reports"], "responses": { "200": { "description": "Reports list" }, "401": { "description": "Unauthorized" } } },
      "post": { "summary": "Save an analysis report", "tags": ["Reports"], "requestBody": { "content": { "application/json": { "schema": { "type": "object" } } } }, "responses": { "201": { "description": "Report saved" }, "401": { "description": "Unauthorized" } } }
    },
    "/history": {
      "get": { "summary": "Get analysis history for authenticated user", "tags": ["History"], "responses": { "200": { "description": "History entries" }, "401": { "description": "Unauthorized" } } }
    },
    "/export/{username}.{format}": {
      "get": {
        "summary": "Export portfolio report",
        "tags": ["Export"],
        "parameters": [
          { "name": "username", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "format", "in": "path", "required": true, "schema": { "type": "string", "enum": ["pdf", "csv", "json"] } }
        ],
        "responses": {
          "200": { "description": "Downloaded file" },
          "400": { "description": "Invalid format" }
        }
      }
    },
    "/badge/{username}.svg": {
      "get": {
        "summary": "Get embeddable portfolio score badge (SVG)",
        "security": [],
        "tags": ["Public"],
        "parameters": [{ "name": "username", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "SVG badge", "content": { "image/svg+xml": {} } } }
      }
    },
    "/github/{path}": {
      "get": {
        "summary": "Cached GitHub API proxy",
        "security": [],
        "tags": ["Proxy"],
        "parameters": [{ "name": "path", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "GitHub API response (cached 5min)" }, "404": { "description": "GitHub resource not found" }, "429": { "description": "Rate limited" } }
      }
    },
    "/admin/dashboard": {
      "get": { "summary": "Admin: real-time dashboard stats", "tags": ["Admin"], "security": [{ "bearerAuth": [] }], "responses": { "200": { "description": "Dashboard analytics" }, "401": { "description": "Unauthorized" }, "403": { "description": "Forbidden — admin role required" } } }
    },
    "/admin/queues": {
      "get": { "summary": "Admin: BullMQ queue stats (job counts, failures, retries)", "tags": ["Admin"], "security": [{ "bearerAuth": [] }], "responses": { "200": { "description": "Queue dashboard" }, "401": { "description": "Unauthorized" }, "403": { "description": "Forbidden" } } }
    },
    "/admin/stats": { "get": { "summary": "Admin: system stats (legacy)", "tags": ["Admin"], "responses": { "200": { "description": "System stats" } } } },
    "/admin/audits": { "get": { "summary": "Admin: audit log entries", "tags": ["Admin"], "parameters": [{ "name": "limit", "in": "query", "schema": { "type": "integer", "default": 50, "maximum": 200 } }], "responses": { "200": { "description": "Audit log" } } } }
  }
}
